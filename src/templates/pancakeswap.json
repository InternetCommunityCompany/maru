{
  "id": "pancakeswap",
  "name": "PancakeSwap",
  "schema": "swap",
  "match": {
    "source": "fetch",
    "method": "GET",
    "urlPattern": "^https://hub-gateway\\.pancakeswap\\.com/v\\d+/quote(\\?|$)"
  },
  "extract": {
    "static": {
      "provider": "PancakeSwap"
    },
    "fields": {
      "chainIn": "$response.data.chainId",
      "chainOut": "$response.data.chainId",
      "tokenIn": "$response.data.srcToken",
      "tokenOut": "$response.data.dstToken",
      "amountIn": "$response.data.inputAmount",
      "amountOut": "$response.data.outputAmount"
    }
  }
}
