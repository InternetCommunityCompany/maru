{
  "id": "paraswap",
  "name": "ParaSwap",
  "version": "1.0.0",
  "schema": "swap",
  "match": {
    "source": "fetch",
    "method": "POST",
    "urlPattern": "^https://apiv\\d+\\.paraswap\\.io/transactions/\\d+(\\?|$)"
  },
  "extract": {
    "static": {
      "provider": "ParaSwap"
    },
    "fields": {
      "chainIn": "$request.priceRoute.network",
      "chainOut": "$request.priceRoute.network",
      "tokenIn": "$request.priceRoute.srcToken",
      "tokenOut": "$request.priceRoute.destToken",
      "amountIn": "$request.priceRoute.srcAmount",
      "amountOut": "$request.priceRoute.destAmount",
      "fromAddress": "$request.userAddress"
    }
  }
}
